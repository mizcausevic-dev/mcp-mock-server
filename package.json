{
  "name": "mcp-mock-server",
  "version": "0.1.0",
  "description": "Productized stdio MCP mock server — reads a tools/list JSON and serves it, with configurable per-tool stubs, latency, error injection, and schema-validation modes (off/lenient/strict). The companion to mcp-tool-schema-fuzzer: tests CLIENT robustness without a real backend.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/mcp-mock-server"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mock",
    "stdio",
    "testing",
    "json-rpc",
    "stub",
    "typescript"
  ],
  "bin": {
    "mcp-mock-server": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx src/cli.ts --help",
    "serve": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
